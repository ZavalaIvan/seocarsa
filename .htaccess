<IfModule mod_rewrite.c>
RewriteEngine On

# =========================
# Rutas heredadas retiradas
# =========================
RewriteRule ^Content/Mutuus(?:/.*)?$ - [G,L,NC]
RewriteRule ^Content/images/Mutuus(?:/.*)?$ - [G,L,NC]

# =========================
# Host canónico y HTTPS
# =========================

RewriteCond %{HTTP_HOST} ^(?:www\.)?carsa\.com\.mx$ [NC,OR]
RewriteCond %{HTTP_HOST} ^www\.carsaseguros\.mx$ [NC]
RewriteRule ^ https://carsaseguros.mx%{REQUEST_URI} [R=301,L]

RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP_HOST} ^carsaseguros\.mx$ [NC]
RewriteRule ^ https://carsaseguros.mx%{REQUEST_URI} [R=301,L]

# =========================
# Redirecciones 301 solo si el usuario pidió la URL vieja
# =========================

RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+contacto\.html[\s?] [NC]
RewriteRule ^contacto\.html$ /contacto [R=301,L]

RewriteCond %{THE_REQUEST} \s/+mapa-del-sitio\.html[\s?] [NC]
RewriteRule ^mapa-del-sitio\.html$ /mapa-del-sitio [R=301,L]

RewriteCond %{THE_REQUEST} \s/+planes-de-ahorro/allianz\.html[\s?] [NC]
RewriteRule ^planes-de-ahorro/allianz\.html$ /plan-personal-de-retiro [R=301,L]

RewriteCond %{THE_REQUEST} \s/+seguros-de-vida/allianz\.html[\s?] [NC]
RewriteRule ^seguros-de-vida/allianz\.html$ /seguro-de-vida [R=301,L]

RewriteCond %{THE_REQUEST} \s/+salud\.html[\s?] [NC]
RewriteRule ^salud\.html$ /gastos-medicos-mayores [R=301,L]

RewriteCond %{THE_REQUEST} \s/+planes-de-ahorro/hogar\.html[\s?] [NC]
RewriteRule ^planes-de-ahorro/hogar\.html$ /seguro-de-hogar [R=301,L]

RewriteCond %{THE_REQUEST} \s/+seguros-de-auto\.html[\s?] [NC]
RewriteRule ^seguros-de-auto\.html$ /seguro-de-auto [R=301,L]

RewriteCond %{THE_REQUEST} \s/+planes-de-ahorro/empresarial\.html[\s?] [NC]
RewriteRule ^planes-de-ahorro/empresarial\.html$ /seguro-empresarial [R=301,L]

RewriteCond %{THE_REQUEST} \s/+Fianzas/cumplimiento\.html[\s?] [NC]
RewriteRule ^Fianzas/cumplimiento\.html$ /fianza-de-cumplimiento [R=301,L]

RewriteCond %{THE_REQUEST} \s/+Fianzas/anticipo\.html[\s?] [NC]
RewriteRule ^Fianzas/anticipo\.html$ /fianza-de-anticipo [R=301,L]

RewriteCond %{THE_REQUEST} \s/+Fianzas/vicios-ocultos\.html[\s?] [NC]
RewriteRule ^Fianzas/vicios-ocultos\.html$ /fianza-de-vicios-ocultos [R=301,L]

RewriteCond %{THE_REQUEST} \s/+Fianzas/credito\.html[\s?] [NC]
RewriteRule ^Fianzas/credito\.html$ /fianza-de-credito [R=301,L]

RewriteCond %{THE_REQUEST} \s/+Fianzas/fidelidad\.html[\s?] [NC]
RewriteRule ^Fianzas/fidelidad\.html$ /fianza-de-fidelidad [R=301,L]

RewriteCond %{THE_REQUEST} \s/+fianzas\.html[\s?] [NC]
RewriteRule ^fianzas\.html$ /fianzas [R=301,L]

RewriteCond %{THE_REQUEST} \s/+recursos\.html[\s?] [NC]
RewriteRule ^recursos\.html$ /recursos [R=301,L]

RewriteCond %{THE_REQUEST} \s/+seguro-de-ahorro[\s?] [NC]
RewriteRule ^seguro-de-ahorro$ /plan-personal-de-retiro [R=301,L]

RewriteCond %{THE_REQUEST} \s/+seguro-medico[\s?] [NC]
RewriteRule ^seguro-medico$ /gastos-medicos-mayores [R=301,L]

# =========================
# Quitar slash final de URLs públicas
# =========================
RewriteRule ^(contacto|mapa-del-sitio|plan-personal-de-retiro|seguro-de-ahorro|seguro-de-vida|gastos-medicos-mayores|seguro-medico|seguro-de-hogar|seguro-de-auto|seguro-empresarial|fianzas|recursos|fianza-de-cumplimiento|fianza-de-anticipo|fianza-de-vicios-ocultos|fianza-de-credito|fianza-de-fidelidad)/$ /$1 [R=301,L,NC]

# =========================
# Hub pages con prioridad
# =========================
RewriteRule ^fianzas$ fianzas.html [L,NC]
RewriteRule ^recursos$ recursos.html [L,NC]

# =========================
# No tocar archivos o carpetas reales
# =========================
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# =========================
# Rewrites internos a archivos físicos
# =========================
RewriteRule ^$ index.html [L]
RewriteRule ^contacto$ contacto.html [L,NC]
RewriteRule ^mapa-del-sitio$ mapa-del-sitio.html [L,NC]
RewriteRule ^plan-personal-de-retiro$ planes-de-ahorro/allianz.html [L,NC]
RewriteRule ^seguro-de-ahorro$ planes-de-ahorro/allianz.html [L,NC]
RewriteRule ^seguro-de-vida$ seguros-de-vida/allianz.html [L,NC]
RewriteRule ^gastos-medicos-mayores$ salud.html [L,NC]
RewriteRule ^seguro-medico$ salud.html [L,NC]
RewriteRule ^seguro-de-hogar$ planes-de-ahorro/hogar.html [L,NC]
RewriteRule ^seguro-de-auto$ seguros-de-auto.html [L,NC]
RewriteRule ^seguro-empresarial$ planes-de-ahorro/empresarial.html [L,NC]
RewriteRule ^fianza-de-cumplimiento$ Fianzas/cumplimiento.html [L,NC]
RewriteRule ^fianza-de-anticipo$ Fianzas/anticipo.html [L,NC]
RewriteRule ^fianza-de-vicios-ocultos$ Fianzas/vicios-ocultos.html [L,NC]
RewriteRule ^fianza-de-credito$ Fianzas/credito.html [L,NC]
RewriteRule ^fianza-de-fidelidad$ Fianzas/fidelidad.html [L,NC]
</IfModule>

# =========================
# Cache de estaticos
# =========================
<IfModule mod_expires.c>
ExpiresActive On

# HTML y XML: siempre validar de nuevo
ExpiresByType text/html "access plus 0 seconds"
ExpiresByType application/xhtml+xml "access plus 0 seconds"
ExpiresByType application/xml "access plus 0 seconds"
ExpiresByType text/xml "access plus 0 seconds"

# CSS y JS: cache larga; cambiar nombre del archivo al actualizarlo
ExpiresByType text/css "access plus 1 year"
ExpiresByType text/javascript "access plus 1 year"
ExpiresByType application/javascript "access plus 1 year"
ExpiresByType application/x-javascript "access plus 1 year"

# Imagenes y fuentes: cache larga
ExpiresByType image/svg+xml "access plus 1 year"
ExpiresByType image/webp "access plus 1 year"
ExpiresByType image/avif "access plus 1 year"
ExpiresByType image/png "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 year"
ExpiresByType image/gif "access plus 1 year"
ExpiresByType image/x-icon "access plus 1 year"
ExpiresByType image/vnd.microsoft.icon "access plus 1 year"
ExpiresByType font/woff2 "access plus 1 year"
ExpiresByType font/woff "access plus 1 year"
ExpiresByType application/font-woff2 "access plus 1 year"
ExpiresByType application/font-woff "access plus 1 year"
ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
ExpiresByType font/ttf "access plus 1 year"
ExpiresByType font/otf "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
# HTML: no cachear sin revalidar
<FilesMatch "\.(html?|xhtml|xml)$">
Header always set Cache-Control "no-cache, must-revalidate"
</FilesMatch>

# Activos estaticos: cache larga e immutable
<FilesMatch "\.(css|js|mjs|png|jpe?g|gif|svg|webp|avif|ico|woff2?|ttf|otf|eot)$">
Header always set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
</IfModule>
